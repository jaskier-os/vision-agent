# WebSocket URL of the orchestrator this agent connects to
ORCHESTRATOR_URL=ws://localhost:10001

# Communicator (LLM gateway) base URL used for image analysis
COMMUNICATOR_URL=http://localhost:10000

# MCP web-search server base URL (provides reverse_image_search)
MCP_URL=http://localhost:10002

# API key for the communicator / MCP services (set to your own value)
API_KEY=

# LLM model id to use for vision analysis
MODEL=sonnet

# Local HTTP port for the agent health endpoint (0 = disabled)
HEALTH_PORT=10005

# Optional OCR microservice base URL (leave unset if not used)
OCR_URL=http://localhost:10006
